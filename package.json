{
  "name": "pitty-pi-ui",
  "version": "0.3.2",
  "private": false,
  "type": "module",
  "description": "PiTTy: a fast, extensible OpenTUI frontend for the Pi coding agent",
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test --conditions=browser",
    "test:ui": "bun test --conditions=browser test/render.test.tsx",
    "diagnostics": "bun run src/diagnostics/collect.ts",
    "test:unit": "bun test --conditions=browser test/conversation.test.ts test/diagnostics.test.ts test/message-window.test.ts test/rpc.test.ts test/subagents.test.ts test/integrations.test.ts test/installers.test.ts",
    "check": "npm run typecheck && npm run test:unit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@opentui/core": "0.4.3",
    "@opentui/solid": "0.4.3",
    "diff": "^9.0.0",
    "solid-js": "1.9.12",
    "strip-ansi": "7.1.2",
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "24.12.2",
    "bun": "1.3.14",
    "typescript": "5.8.2"
  },
  "license": "MIT",
  "author": "Jirka Svítil",
  "homepage": "https://github.com/mistrjirka/PiTTy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mistrjirka/PiTTy.git"
  },
  "bugs": {
    "url": "https://github.com/mistrjirka/PiTTy/issues"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "terminal",
    "tui",
    "opentui",
    "ai",
    "developer-tools"
  ],
  "bin": {
    "pitty": "./bin/pitty.mjs"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
